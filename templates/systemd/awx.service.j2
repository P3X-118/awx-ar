[Unit]
Description=AWX ({{ awx_identifier }})
{% for service in awx_systemd_required_services_list %}
Requires={{ service }}
After={{ service }}
{% endfor %}
{% for service in awx_systemd_wanted_services_list %}
Wants={{ service }}
{% endfor %}
DefaultDependencies=no

[Service]
Type=simple
Environment="HOME={{ sysd_docker_unit_home_path }}"
ExecStartPre=-{{ sysd_docker_host_sh }} -c '{{ sysd_docker_host_command }} stop -t {{ sysd_docker_stop_grace }} {{ awx_identifier }} 2>/dev/null || true'
ExecStartPre=-{{ sysd_docker_host_sh }} -c '{{ sysd_docker_host_command }} rm {{ awx_identifier }} 2>/dev/null || true'

ExecStartPre={{ sysd_docker_host_command }} create \
      --rm \
      --name={{ awx_identifier }} \
      --log-driver=none \
      --user={{ awx_uid }}:{{ awx_gid }} \
      --label-file={{ awx_base_path }}/labels \
      --cap-add=CHOWN \
      --cap-add=DAC_OVERRIDE \
      --cap-add=SETUID \
      --cap-add=SETGID \
      --cap-add=NET_BIND_SERVICE \
      --cap-drop=ALL \
      --network={{ awx_container_network }} \
      {% if awx_container_http_host_bind_port %}
      -p {{ awx_container_http_host_bind_port }}:{{ awx_container_http_port }} \
      {% endif %}
      --env-file={{ awx_base_path }}/env \
      --volume={{ awx_projects_storage_path }}:/var/lib/awx/projects:rw \
      --volume={{ awx_data_path }}:/var/lib/awx/.local/share/containers:rw \
      --tmpfs /run:uid={{ awx_uid }},mode=0755 \
      --tmpfs /var/lib/nginx/tmp:uid={{ awx_uid }},mode=0755 \
      --volume={{ awx_base_path }}/nginx.conf:/etc/nginx/nginx.conf:ro \
      --volume={{ awx_base_path }}/tower/settings.py:/etc/tower/settings.py:ro \
      --volume={{ awx_base_path }}/supervisor:/var/run/supervisor:rw \
      {% for volume in awx_container_additional_volumes %}
      --mount type={{ volume.type | default('bind' if '/' in volume.src else 'volume') }},src={{ volume.src }},dst={{ volume.dst }}{{ (',' + volume.options) if volume.options else '' }} \
      {% endfor %}
      {% for arg in awx_container_extra_arguments %}
      {{ arg }} \
      {% endfor %}
      {{ awx_container_image }} \
      /usr/bin/launch_awx_web.sh

{% for network in awx_container_additional_networks %}
ExecStartPre={{ sysd_docker_host_command }} network connect {{ network }} {{ awx_identifier }}
{% endfor %}

ExecStart={{ sysd_docker_host_command }} start --attach {{ awx_identifier }}

ExecStop=-{{ sysd_docker_host_sh }} -c '{{ sysd_docker_host_command }} stop -t {{ sysd_docker_stop_grace }} {{ awx_identifier }} 2>/dev/null || true'
ExecStop=-{{ sysd_docker_host_sh }} -c '{{ sysd_docker_host_command }} rm {{ awx_identifier }} 2>/dev/null || true'

Restart=always
RestartSec=30
SyslogIdentifier={{ awx_identifier }}

[Install]
WantedBy=multi-user.target
